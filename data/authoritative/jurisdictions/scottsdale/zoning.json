  },
  "service": {
    "status": "configured",
    "provider": "City of Scottsdale GIS",
    "serviceType": "ARCGIS_MAP_SERVER_FEATURE_LAYER",
    "serviceUrl": "https://maps.scottsdaleaz.gov/arcgis/rest/services/OpenData/MapServer",
    "layerId": 24,
    "layerName": "Zoning",
    "publicAccess": true,
    "authenticationRequired": false,
    "authoritative": true
  },
  "query": {
    "method": "POINT_INTERSECTION",
    "geometryType": "esriGeometryPoint",
    "inputSpatialReference": 4326,
    "spatialRelationship": "esriSpatialRelIntersects",
    "where": "1=1",
    "outFields": [
      "full_zoning",
      "comparable_zoning"
    ],
    "returnGeometry": false,
    "resultRecordCount": 10,
    "responseFormat": "json",
    "timeoutSeconds": 8
  },
  "fieldMapping": {
    "zoningCode": [
      "full_zoning",
      "comparable_zoning"
    ],
    "comparableZoningCode": [
      "comparable_zoning"
    ],
    "zoningDescription": [],
    "caseNumber": [],
    "ordinanceNumber": [],
    "historic": [],
    "transitOrientedDevelopment": []
  },
  "normalization": {
    "trimValues": true,
    "collapseWhitespace": true,
    "uppercaseZoningCode": false,
    "emptyValuesAreNull": true,
    "emptyValueTokens": [
      "",
      " "
    ]
  },
  "validation": {
    "availabilityRequired": false,
    "httpFailureIsViolation": false,
    "requiresReviewWhenUnavailable": true,
    "requiresReviewWhenNoResult": true,
    "requiresReviewWhenMultipleResults": true,
    "successfulResultConfidence": 95
  },
  "governance": {
    "tier": "Tier-3",
    "authorityLevel": "EXTERNAL_CANONICAL_SOURCE",
    "autoAcceptChanges": false,
    "requiresInterpretation": true
  },
