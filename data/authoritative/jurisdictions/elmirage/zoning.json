    "sourceOrganizationId": "CRH3aZydoRH1XVod",
    "sourceDataLastEditedDate": "2026-03-17",
    "testAddress": "10000 N El Mirage Rd, El Mirage, AZ 85335",
    "testCoordinate": {
      "latitude": 33.5729888,
