{
  "schema": {
    "name": "SKYESOFT_JURISDICTION_ZONING_SOURCE",
    "version": "1.0.0"
  },
  "jurisdiction": {
    "label": "El Mirage",
    "slug": "elmirage",
    "jurisdictionType": "City",
    "county": "Maricopa",
    "state": "AZ",
    "country": "US"
  },
  "service": {
    "status": "configured",
    "provider": "City of El Mirage Development Services Department",
    "serviceType": "ARCGIS_FEATURE_SERVER_LAYER",
    "serviceUrl": "https://services7.arcgis.com/CRH3aZydoRH1XVod/arcgis/rest/services/Zoning_Dissolved/FeatureServer",
    "layerId": 0,
    "layerName": "Zoning",
    "publicAccess": true,
    "authenticationRequired": false,
    "authoritative": true
  },
  "query": {
    "method": "POINT_INTERSECTION",
    "geometryType": "esriGeometryPoint",
    "inputSpatialReference": 4326,
    "spatialRelationship": "esriSpatialRelIntersects",
    "where": "1=1",
    "outFields": [
      "FBDCC"
    ],
    "returnGeometry": false,
    "resultRecordCount": 10,
    "responseFormat": "json",
    "timeoutSeconds": 8
  },
  "fieldMapping": {
    "zoningCode": [
      "FBDCC"
    ],
    "zoningDescription": [],
    "parcelNumber": [],
    "overlay": [],
    "caseNumber": [],
    "ordinanceNumber": [],
    "historic": [],
    "transitOrientedDevelopment": []
  },
  "codedValueMappings": {
    "FBDCC": {
      "NATURAL RESERVE": {
        "zoningCode": "NR",
        "zoningDescription": "Natural Reserve"
      },
      "RURAL AREA": {
        "zoningCode": "RA",
        "zoningDescription": "Rural Area"
      },
      "SUBURBAN NEIGHBORHOOD": {
        "zoningCode": "SN",
        "zoningDescription": "Suburban Neighborhood"
      },
      "MOBILE PARK": {
        "zoningCode": "MP",
        "zoningDescription": "Mobile Park"
      },
      "MIXED URBAN": {
        "zoningCode": "MU",
        "zoningDescription": "Mixed Urban"
      },
      "URBAN CORRIDOR": {
        "zoningCode": "UC",
        "zoningDescription": "Urban Corridor"
      },
      "TRANSIT DEVELOPMENT": {
        "zoningCode": "TD",
        "zoningDescription": "Transit Development"
      },
      "COMMERCE PARK": {
        "zoningCode": "CP",
        "zoningDescription": "Commerce Park"
      },
      "EMPLOYMENT/INDUSTRY": {
        "zoningCode": "EI",
        "zoningDescription": "Employment / Industry"
      },
      "PLANNED AREA DEVELOPMENT": {
        "zoningCode": "PAD",
        "zoningDescription": "Planned Area Development"
      }
    }
  },
  "normalization": {
    "trimValues": true,
    "collapseWhitespace": true,
    "uppercaseZoningCode": true,
    "emptyValuesAreNull": true,
    "emptyValueTokens": [
      "",
      " "
    ]
  },
  "validation": {
    "availabilityRequired": false,
    "httpFailureIsViolation": false,
    "requiresReviewWhenUnavailable": true,
    "requiresReviewWhenNoResult": true,
    "requiresReviewWhenMultipleResults": true,
    "successfulResultConfidence": 95
  },
  "governance": {
    "tier": "Tier-3",
    "authorityLevel": "EXTERNAL_CANONICAL_SOURCE",
    "autoAcceptChanges": false,
    "requiresInterpretation": true
  },
  "metadata": {
