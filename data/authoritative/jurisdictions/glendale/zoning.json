    "returnGeometry": false,
    "resultRecordCount": 10,
    "responseFormat": "json",
    "timeoutSeconds": 8
  },
  "fieldMapping": {
    "zoningCode": [
      "BASE_ZONE",
      "ZONING"
    ],
    "zoningDescription": [
