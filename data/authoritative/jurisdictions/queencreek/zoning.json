{
  "schema": {
    "name": "SKYESOFT_JURISDICTION_ZONING_SOURCE",
    "version": "1.0.0"
  },
  "jurisdiction": {
    "label": "Queen Creek",
    "slug": "queen-creek",
    "jurisdictionType": "Town",
    "county": "Maricopa",
    "state": "AZ",
    "country": "US"
  },
  "service": {
    "status": "configured",
    "provider": "Town of Queen Creek Community Development Department",
    "serviceType": "ARCGIS_MAP_SERVER_FEATURE_LAYER",
    "serviceUrl": "https://gis.queencreekaz.gov/arcgis/rest/services/Public/Zoning/MapServer",
    "layerId": 0,
    "layerName": "Zoning",
    "publicAccess": true,
    "authenticationRequired": false,
    "authoritative": true
  },
  "query": {
    "method": "POINT_INTERSECTION",
    "geometryType": "esriGeometryPoint",
    "inputSpatialReference": 4326,
    "spatialRelationship": "esriSpatialRelIntersects",
    "where": "1=1",
    "outFields": [
      "ZONING",
      "ZONE_CODE",
      "ZONE_DESC",
      "ZONING_DES"
    ],
    "returnGeometry": false,
    "resultRecordCount": 10,
    "responseFormat": "json",
    "timeoutSeconds": 8
  },
  "fieldMapping": {
    "zoningCode": [
      "ZONING",
      "ZONE_CODE"
    ],
    "zoningDescription": [
      "ZONE_DESC",
      "ZONING_DES"
    ]
  },
  "normalization": {
    "trimValues": true,
    "collapseWhitespace": true,
    "uppercaseZoningCode": true,
    "emptyValuesAreNull": true,
    "emptyValueTokens": [
      "",
      " "
    ]
  },
  "validation": {
    "availabilityRequired": false,
    "httpFailureIsViolation": false,
    "requiresReviewWhenUnavailable": true,
    "requiresReviewWhenNoResult": true,
    "requiresReviewWhenMultipleResults": true,
    "successfulResultConfidence": 95
  },
  "governance": {
    "tier": "Tier-3",
    "authorityLevel": "EXTERNAL_CANONICAL_SOURCE",
    "autoAcceptChanges": false,
    "requiresInterpretation": true
  },
  "metadata": {
    "verifiedAt": 1784303000,
    "verifiedDate": "2026-07-17",
    "verifiedBy": "Skyesoft",
    "testCoordinate": {
      "latitude": 33.248311,
      "longitude": -111.634122,
      "expectedZoningCode": "R1-43",
      "expectedZoningDescription": "Single-Family Residential"
    }
  },
  "notes": [
    "Resolves Town of Queen Creek zoning by intersecting coordinates against Layer 0 of their public GIS service.",
    "Supports both Maricopa and Pinal county portions within the incorporated town limits."
  ]
}